{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/style.css",
      "destination": "/community/style.css"
    },
    {
      "source": "/app.js",
      "destination": "/community/app.js"
    },
    {
      "source": "/tools/(.*)",
      "destination": "/community/tools/$1"
    },
    {
      "source": "/themes/(.*)",
      "destination": "/community/themes/$1"
    },
    {
      "source": "/",
      "destination": "/community/index.html"
    },
    {
      "source": "/((?!community|api|_next).*)",
      "destination": "/community/$1"
    }
  ]
}
